# Docker Compose directory path
COMPOSE_DIR=/mnt/user/compose

# Proxy configuration directory path
PROXY_DIR=/mnt/user/appdata/swag/nginx/proxy-confs

# Notification settings (optional)
GOTIFY_URL=https://gotify.yourdomain.com
GOTIFY_TOKEN=your-gotify-token

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=1

# Python settings
PYTHONPATH=/app
PYTHONUNBUFFERED=1

# Gunicorn settings
GUNICORN_CMD_ARGS="--reload --worker-class=geventwebsocket.gunicorn.workers.GeventWebSocketWorker --workers=3 --log-level=debug --timeout=120 --capture-output --enable-stdio-inheritance"
